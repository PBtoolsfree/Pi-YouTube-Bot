# Force LF line endings for all shell scripts
# This prevents the status=203/EXEC error on Raspberry Pi
# (bash rejects scripts with Windows CRLF \r\n endings)

* text=auto

# Shell scripts MUST use LF — never CRLF
*.sh text eol=lf

# Python files use LF
*.py text eol=lf

# Other text files
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.mp3 binary
*.mp4 binary
