# ============================================================
#  Pi YouTube Bot — Environment Variables (.env)
#  Copy this file to .env and fill in your values.
#  .env is gitignored — it WILL NOT be committed to GitHub.
#  Priority: OS env vars > .env file > config.json > defaults
# ============================================================

# ── Server ──────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000

# ── AI Providers ────────────────────────────────────────────
# At least one AI key is required for auto-reply to work.

# Google Gemini (recommended — free tier available)
# GEMINI_API_KEY=AIzaSy...

# OpenAI (GPT-4o, GPT-3.5)
# OPENAI_API_KEY=sk-...

# OpenRouter (access 50+ models with one key)
# OPENROUTER_API_KEY=sk-or-...

# Groq (ultra-fast inference, free tier)
# GROQ_API_KEY=gsk_...

# Ollama (local AI — no key needed, just host)
# OLLAMA_HOST=http://localhost:11434

# ── Telegram Bot ─────────────────────────────────────────────
# Get from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
# TELEGRAM_CHAT_ID=-100...

# ── Google OAuth (YouTube authentication) ───────────────────
# From Google Cloud Console → OAuth 2.0 Credentials
# See client_secret.example.json for setup instructions
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── OBS Overlay (WebSocket) ──────────────────────────────────
# OBS_WS_HOST=localhost
# OBS_WS_PORT=4455
# OBS_WS_PASSWORD=

# ── Security ─────────────────────────────────────────────────
# Protect donation webhooks — use a long random string
# WEBHOOK_SECRET=use-a-long-random-string-here

# ── Email Verification (Paytm donation alerts) ───────────────
# IMAP email for scanning payment confirmation emails
# EMAIL_HOST=imap.gmail.com
# EMAIL_PORT=993
# EMAIL_USER=yourbot@gmail.com
# EMAIL_PASS=your-app-password-not-real-password

# ── Payment Gateways ─────────────────────────────────────────
# PhonePe merchant credentials
# PHONEPE_MERCHANT_ID=MERCHANTXXXXXX
# PHONEPE_SALT_KEY=your-phonepe-salt-key
# PHONEPE_SALT_INDEX=1

# ── Supabase (optional cloud database) ───────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
